<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<h1>Customers</h1>
<a href="/customers/new" class="btn">New Customer</a>

<% if (customers.length) { %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Industry</th>
        <th>Phone</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% customers.forEach(function(c) { %>
        <tr>
          <td><a href="/customers/<%= c.id %>"><%= c.name %></a></td>
          <td><%= c.industry || '—' %></td>
          <td><%= c.phone || '—' %></td>
          <td class="actions">
            <a href="/customers/<%= c.id %>/edit" class="btn-sm">Edit</a>
            <form action="/customers/<%= c.id %>?_method=DELETE" method="POST" class="inline">
              <button type="submit" class="btn-sm btn-danger" onclick="return confirm('Delete this customer?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else { %>
  <p class="empty-state">No customers yet. <a href="/customers/new">Add one →</a></p>
<% } %>

<%- include('../partials/footer') %>
